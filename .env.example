# syntraq — environment variables (template)
# copy this file to `.env` and fill in real values. `.env` is gitignored.
# every key read by nuxt.config.ts runtimeConfig is listed here.

# ─── app ───────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_URL=http://localhost:3000
# public base url of the app; used in emails, stripe redirects, webhooks.

NODE_ENV=development
# `development` | `production` | `test`

# ─── database ──────────────────────────────────────────────────────────────
DATABASE_URL=file:./db.sqlite
# local sqlite file for dev. keep as-is unless pointing at a different file.

# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# production libsql url from turso dashboard.

# TURSO_AUTH_TOKEN=your-turso-token
# generated in turso dashboard → database → tokens. treat as a secret.

# ─── auth ──────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production
# random 32+ byte hex string. generate with: `openssl rand -hex 32`.
# rotating this invalidates every active session.

# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# from google cloud console → apis & services → credentials → oauth client id.
# callback url: ${NUXT_PUBLIC_APP_URL}/api/auth/oauth/google/callback

# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=
# OAUTH_MICROSOFT_TENANT=common
# from azure ad → app registrations. tenant can be `common`, `organizations`,
# `consumers`, or a specific tenant id. callback url:
# ${NUXT_PUBLIC_APP_URL}/api/auth/oauth/microsoft/callback

# ─── stripe ────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxx
# server-only key. from stripe dashboard → developers → api keys.

# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# client-safe key; exposed via runtimeConfig.public.

# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# from stripe dashboard → developers → webhooks → signing secret.
# required for verifying incoming webhooks.

# ─── email ─────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER=resend
# provider slug understood by emailService. leave blank to log to console.

# EMAIL_API_KEY=re_xxxxx
# api key from your email provider (e.g. resend).

# EMAIL_FROM=noreply@syntraq.io
# verified sender address. must match a verified domain in the provider.

# ─── analytics ─────────────────────────────────────────────────────────────
# ANALYTICS_ENABLED=true
# toggles the `/api/analytics/track` endpoint + client-side emit.

# ─── queue (future — improvement phase 12) ─────────────────────────────────
# REDIS_URL=redis://localhost:6379
# required once bullmq is wired. upstash url also works.

# ─── observability (future — improvement phase 5) ──────────────────────────
# SENTRY_DSN=
# server + client error tracking.

# LOG_LEVEL=info
# `trace` | `debug` | `info` | `warn` | `error`

# ─── public api cors (improvement phase 2) ─────────────────────────────────
# PUBLIC_API_CORS_ORIGINS=https://partner.example.com,https://ops.example.com
# comma-separated list of origins allowed to call /api/public/*.
# leave unset to fall back to the default localhost allowlist (dev only).

# ─── secret rotation notes ─────────────────────────────────────────────────
# AUTH_SECRET       — rotate on any suspected leak. invalidates all sessions.
# STRIPE_SECRET_KEY — rotate from stripe dashboard → api keys → roll.
# STRIPE_WEBHOOK_SECRET — rotate by creating a new endpoint, updating here, then deleting the old.
# EMAIL_API_KEY     — rotate from your provider console; keep the old valid for 24h overlap.
# TURSO_AUTH_TOKEN  — rotate via turso cli; update prod env and redeploy immediately.
# api keys issued to customers rotate via POST /api/api-keys/rotate (returns the new plaintext once).
